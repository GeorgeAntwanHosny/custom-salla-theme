{% extends 'layouts/master' %}

{% block seo %}
    <title>{{ blog.title }} — {{ store.name }}</title>
    {% if blog.excerpt %}
        <meta name="description" content="{{ blog.excerpt }}">
    {% endif %}
{% endblock %}

{% block content %}
<div class="container" style="padding:3rem 1.5rem; max-width:860px;">

    <nav class="breadcrumbs" style="margin-bottom:1.5rem;">
        <ol>
            <li><a href="{{ store.url }}">{{ trans('pages.home') }}</a></li>
            <li><a href="{{ store.url }}/blog">{{ trans('pages.blog') }}</a></li>
            <li aria-current="page">{{ blog.title }}</li>
        </ol>
    </nav>

    {% if blog.image %}
        <img src="{{ blog.image }}" alt="{{ blog.title }}"
             style="width:100%; max-height:450px; object-fit:cover; border-radius:var(--radius-lg); margin-bottom:2rem;">
    {% endif %}

    <h1 style="font-size:2rem; font-weight:800; margin-bottom:1rem;">{{ blog.title }}</h1>

    {% if blog.published_at %}
        <time style="font-size:13px; color:#9ca3af; display:block; margin-bottom:2rem;">
            {{ blog.published_at | date('d M Y') }}
        </time>
    {% endif %}

    <div class="rich-text">
        {{ blog.content | raw }}
    </div>

    {# Comments #}
    {% include 'components/comments' ignore missing %}

</div>
{% endblock %}
