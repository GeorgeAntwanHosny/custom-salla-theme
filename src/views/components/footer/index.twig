{#
  Footer Component — src/views/components/footer/index.twig
  Multi-column footer: links, contact, social, payment methods
#}

<footer class="site-footer" style="background: var(--footer-bg);">
    <div class="container footer-grid">

        {# ── Col 1: About / Logo ── #}
        <div class="footer-col footer-col--about">
            <a href="{{ store.url }}" class="footer-logo">
                {% if store.logo %}
                    <img src="{{ store.logo }}" alt="{{ store.name }}" width="130" loading="lazy">
                {% else %}
                    <span class="footer-logo__text">{{ store.name }}</span>
                {% endif %}
            </a>
            {% if store.description %}
                <p class="footer-about__text">{{ store.description }}</p>
            {% endif %}

            {# Social icons #}
            <div class="footer-social">
                {% if store.social.twitter %}
                    <a href="{{ store.social.twitter }}" target="_blank" rel="noopener" aria-label="Twitter" class="footer-social__link">
                        <salla-icon name="twitter"></salla-icon>
                    </a>
                {% endif %}
                {% if store.social.instagram %}
                    <a href="{{ store.social.instagram }}" target="_blank" rel="noopener" aria-label="Instagram" class="footer-social__link">
                        <salla-icon name="instagram"></salla-icon>
                    </a>
                {% endif %}
                {% if store.social.snapchat %}
                    <a href="{{ store.social.snapchat }}" target="_blank" rel="noopener" aria-label="Snapchat" class="footer-social__link">
                        <salla-icon name="snapchat"></salla-icon>
                    </a>
                {% endif %}
                {% if store.social.tiktok %}
                    <a href="{{ store.social.tiktok }}" target="_blank" rel="noopener" aria-label="TikTok" class="footer-social__link">
                        <salla-icon name="tiktok"></salla-icon>
                    </a>
                {% endif %}
                {% if store.social.facebook %}
                    <a href="{{ store.social.facebook }}" target="_blank" rel="noopener" aria-label="Facebook" class="footer-social__link">
                        <salla-icon name="facebook"></salla-icon>
                    </a>
                {% endif %}
            </div>
        </div>

        {# ── Col 2: Quick Links ── #}
        <div class="footer-col">
            <h4 class="footer-col__title">{{ trans('footer.quick_links') | default('Quick Links') }}</h4>
            <ul class="footer-links">
                <li><a href="{{ store.url }}">{{ trans('pages.home') }}</a></li>
                <li><a href="{{ store.url }}/shop">{{ trans('pages.products') }}</a></li>
                <li><a href="{{ store.url }}/brands">{{ trans('pages.brands') }}</a></li>
                {% if store.blog_enabled %}
                    <li><a href="{{ store.url }}/blog">{{ trans('pages.blog') }}</a></li>
                {% endif %}
                <li><a href="{{ store.url }}/cart">{{ trans('pages.cart') }}</a></li>
            </ul>
        </div>

        {# ── Col 3: Static Pages from merchant ── #}
        {% if store.pages %}
            <div class="footer-col">
                <h4 class="footer-col__title">{{ trans('footer.help') | default('Help') }}</h4>
                <ul class="footer-links">
                    {% for page in store.pages %}
                        <li><a href="{{ page.url }}">{{ page.title }}</a></li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}

        {# ── Col 4: Contact ── #}
        <div class="footer-col">
            <h4 class="footer-col__title">{{ trans('footer.contact') | default('Contact Us') }}</h4>
            <ul class="footer-links footer-links--contact">
                {% if store.email %}
                    <li>
                        <salla-icon name="envelope"></salla-icon>
                        <a href="mailto:{{ store.email }}">{{ store.email }}</a>
                    </li>
                {% endif %}
                {% if store.phone %}
                    <li>
                        <salla-icon name="phone"></salla-icon>
                        <a href="tel:{{ store.phone }}">{{ store.phone }}</a>
                    </li>
                {% endif %}
                {% if store.whatsapp %}
                    <li>
                        <salla-icon name="whatsapp"></salla-icon>
                        <a href="https://wa.me/{{ store.whatsapp }}" target="_blank" rel="noopener">WhatsApp</a>
                    </li>
                {% endif %}
            </ul>

            {# Store App download links #}
            {% if store.android_app or store.ios_app %}
                <div class="footer-apps">
                    {% if store.ios_app %}
                        <a href="{{ store.ios_app }}" target="_blank" rel="noopener" class="footer-app-badge">
                            <img src="{{ 'images/app-store.svg' | asset }}" alt="Download on App Store" loading="lazy">
                        </a>
                    {% endif %}
                    {% if store.android_app %}
                        <a href="{{ store.android_app }}" target="_blank" rel="noopener" class="footer-app-badge">
                            <img src="{{ 'images/google-play.svg' | asset }}" alt="Get it on Google Play" loading="lazy">
                        </a>
                    {% endif %}
                </div>
            {% endif %}
        </div>

    </div>

    {# ── Bottom bar ── #}
    <div class="footer-bottom">
        <div class="container footer-bottom__inner">
            <p class="footer-bottom__copy">
                &copy; {{ 'now' | date('Y') }} {{ store.name }}. {{ trans('footer.all_rights') | default('All rights reserved.') }}
                &mdash; Powered by <a href="https://salla.com" target="_blank" rel="noopener">Salla</a>
            </p>

            {# Payment method icons — Salla provides these via web component #}
            <div class="footer-payments">
                <salla-payment-icons></salla-payment-icons>
            </div>
        </div>
    </div>

</footer>
