<!DOCTYPE html>
<html lang="{{ store.language }}" dir="{{ store.direction }}" class="{{ store.direction == 'rtl' ? 'rtl' : 'ltr' }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="{{ settings.primary_color }}">

    {# Required Salla SEO meta tags #}
    {{ page.title }} | {{ store.name }}
    {% block seo %}{% endblock %}

    {# Hook: head start — inject Salla's required scripts #}
    {% hook 'head:start' %}

    {# Google Fonts based on merchant setting #}
    {% set font = settings.font_family | default('cairo') %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family={{ font | capitalize }}:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    {# Theme CSS variables — driven by merchant settings #}
    <style>
        :root {
            --primary:        {{ settings.primary_color | default('#2563eb') }};
            --primary-dark:   color-mix(in srgb, {{ settings.primary_color | default('#2563eb') }} 80%, black);
            --primary-light:  color-mix(in srgb, {{ settings.primary_color | default('#2563eb') }} 20%, white);
            --footer-bg:      {{ settings.footer_bg | default('#111827') }};
            --font-base:      '{{ font | capitalize }}', sans-serif;
            --radius-sm:      6px;
            --radius-md:      10px;
            --radius-lg:      16px;
            --shadow-sm:      0 1px 3px rgba(0,0,0,.08);
            --shadow-md:      0 4px 16px rgba(0,0,0,.10);
            --shadow-lg:      0 8px 32px rgba(0,0,0,.14);
            --transition:     all 0.25s ease;
        }
        *, *::before, *::after { box-sizing: border-box; }
        body {
            font-family: var(--font-base);
            margin: 0;
            padding: 0;
            color: #1f2937;
            background: #ffffff;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        main { flex: 1; }
        img { max-width: 100%; height: auto; }
        a { color: inherit; text-decoration: none; }
    </style>

    {# Compiled theme CSS #}
    <link rel="stylesheet" href="{{ 'css/theme.css' | asset }}">

    {# Hook: head end #}
    {% hook 'head:end' %}
</head>

<body class="{% if settings.topnav_is_dark %}header-dark{% endif %}">

    {# Announcement Bar #}
    {% if settings.show_announcements_bar %}
        <div class="announcement-bar">
            <span>{{ settings.announcement_text }}</span>
        </div>
    {% endif %}

    {# ===== HEADER ===== #}
    {% include 'components/header/index' %}

    {# ===== MAIN CONTENT ===== #}
    <main id="main-content">
        {% block content %}{% endblock %}
    </main>

    {# ===== FOOTER ===== #}
    {% include 'components/footer/index' %}

    {# Salla Web Components — always include #}
    <salla-cart-summary></salla-cart-summary>
    <salla-search-popup></salla-search-popup>
    <salla-login-modal></salla-login-modal>

    {# Hook: body:end — Salla JS SDK injection happens here. REQUIRED. #}
    {% hook 'body:end' %}

    {# Compiled theme JS #}
    <script src="{{ 'js/theme.js' | asset }}" defer></script>

</body>
</html>
